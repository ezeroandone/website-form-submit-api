{
  "name": "formsend-api",
  "version": "2.0.0",
  "description": "FormSend — Cloudflare Worker backend",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create formsend-db",
    "db:migrate": "wrangler d1 execute formsend-db --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute formsend-db --remote --file=./schema.sql",
    "kv:create": "wrangler kv namespace create SESSIONS",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "resend": "^3.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "typescript": "^5.5.4",
    "wrangler": "^3.78.12"
  }
}
