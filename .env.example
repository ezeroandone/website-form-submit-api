# ══════════════════════════════════════════════════════════════════
#  FormSend API — Environment Variables Reference
#
#  For LOCAL DEV:  copy this to .dev.vars (not .env — Wrangler reads .dev.vars)
#  For PRODUCTION: use `wrangler secret put VARIABLE_NAME` for each one
#                  the two [vars] entries (FRONTEND_URL, API_URL) live in wrangler.toml
# ══════════════════════════════════════════════════════════════════

# ─── Google OAuth ──────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URIs must include:
#   Production: https://api.formsend.ezeroandone.io/auth/callback
#   Local dev:  http://localhost:8787/auth/callback
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Resend (email delivery) ───────────────────────────────────
# Create at: https://resend.com/api-keys
# Domain ezeroandone.io must be verified in Resend before using a custom from address
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=FormSend <noreply@ezeroandone.io>

# ─── Paystack (payments) ───────────────────────────────────────
# Found at: https://dashboard.paystack.com → Settings → API Keys & Webhooks
# Use sk_test_... for dev, sk_live_... for production
# Webhook URL to register in Paystack dashboard (not used in code — for reference):
#   https://api.formsend.ezeroandone.io/api/payment/webhook
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Admin account ─────────────────────────────────────────────
# The Google account email that gets auto-promoted to admin on first login
ADMIN_GOOGLE_EMAIL=ezeroandone@gmail.com

# ─── URLs (also set as [vars] in wrangler.toml) ────────────────
# Production values are already in wrangler.toml — only needed here for .dev.vars
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8787
